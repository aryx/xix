\section{Window threads}

%claude:
Each window has its own thread running an event loop that listens
on multiple channels simultaneously using [[Event.select]]:
keyboard events (from the keyboard thread), mouse events (from the
mouse thread), control commands (resize, delete), and---for the
virtual device protocol---channels to send mouse states and
console data to the filesystem server. This is the {active object}
pattern: each window is an autonomous entity with its own event loop.

<<signature [[Threads_window.thread]]>>=
(* Thread listening to keyboard/mouse/wm events for a particular window
 * and dispatching to the right channel.
 *)
val thread: Window.t -> unit
@

<<type [[Threads_window.event]]>>=
type event = 
  (* reading from keyboard thread *)
  | Key   of Keyboard.key
  (* reading from mouse thread *)
  | Mouse of Mouse.state
  (* reading from many places *)
  | Cmd   of Window.cmd

  <<[[Threads_window.event]] other cases>>
@
% those are all 'reading', but we will see later can also have 'sending'

%claude:
The event loop is the heart of each window. Note that the
[[Event.select]] call contains not only [[Event.receive]] entries
(for incoming keyboard, mouse, and command events) but also
[[Event.send]] entries (for outgoing data to the filesystem
server). This is a key insight: [[select]] can dispatch on both
receiving {\em and} sending---whichever side is ready first wins.
The send entries are conditional: they are only included in the
list when there is data ready to send (e.g., a new mouse state
or a newline in the text buffer).

<<function [[Threads_window.thread]]>>=
let thread (w : Window.t) =
  (* less: threadsetname *)
  <<[[Threads_window.thread()]] channels creation>>

  while true do
    let ev = (
    (* receive *)
    [
      Event.receive w.chan_keyboard |> wrap (fun x -> Key x);
      Event.receive w.chan_mouse    |> wrap (fun x -> Mouse x);
      Event.receive w.chan_cmd      |> wrap (fun x -> Cmd x);
    ] @
      <<[[Threads_window.thread()]] other [[select]] elements>>
      []
    ) |> Event.select
    in
    (match ev with
    | Key key -> 
      key_in w key
    | Mouse m -> 
      mouse_in w m
    | Cmd cmd -> 
      (* todo: if return Exited then threadsexit and free channels.
       * When answer Exited? when Cmd is Exited?
       *)
      cmd_in w cmd
    <<[[Threads_window.thread()]] match [[ev]] other cases>>
    );
    if not w.deleted
    then Image.flush w.img;
  done
@

% again, those are all Event.receive but in select can also have
% Event.send

<<function [[Threads_window.wrap]]>>=
let wrap f = 
  fun ev -> Event.wrap ev f
@

<<[[Window.t]] command fields>>=
(* Threads_window.thread <-- Thread_mouse.thread? | ?? *)
(* less: also list of cmds? [20]? *)
chan_cmd: cmd Event.channel;
@

<<type [[Window.cmd]]>>=
type cmd =
  <<[[Window.cmd]] cases>>
@

<<[[Window.cmd]] cases>>=
| Delete
@
