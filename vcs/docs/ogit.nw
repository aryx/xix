<<constant [[Unzip.fixed_huffman]]>>=
let fixed_huffman = 
  make_huffman (Array.init 288 (fun n ->
    if n <= 143 then 8
    else if n <= 255 then 9
    else if n <= 279 then 7
    else 8
  )) 0 288 10
