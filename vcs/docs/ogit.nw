<<constant [[Cmd_pull.cmd]]>>=
let cmd = { Cmd_.
  name = "pull";
  usage = " [options] [<url repository>]";
  options = [
  ];
  f = (fun args ->
    let dst, _ = Repository.find_root_open_and_adjust_paths [] in
