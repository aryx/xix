 *  hard to use mk recursively, hence the use of vars_we_set below)
 * less: could allow to redefine in strict mode if previous
 *  def was empty.
 *)
| _ when Hashtbl.mem env.vars s && Hashtbl.mem env.vars_we_set s 
    && !Flags.strict_mode ->
  raise (Redefinition s)
