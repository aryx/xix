%******************************************************************************
\chapter{Virtual Devices}
%******************************************************************************
\label{chap:virtual-devices}

%claude:
This chapter presents the implementation of the virtual device
files: [[/mnt/wsys/mouse]], [[/mnt/wsys/cons]], [[/mnt/wsys/consctl]],
[[/mnt/wsys/cursor]], and [[/mnt/wsys/winname]]. When a client
process reads or writes these files, the 9P request is dispatched
to the corresponding [[Device.t]] callbacks defined here.
%claude:
The most interesting aspect is the {channel-of-channels} protocol
used for [[/dev/mouse]] and [[/dev/cons]]: the filesystem server
thread and the window thread communicate through a two-step
handshake where one side sends a channel, and the other side uses
that channel to send the actual data. This indirection is needed
because [[Event.select]] can only wait on channels, not on arbitrary
conditions.

\section{[[/mnt/wsys/mouse]]}

<<signature [[Virtual_mouse.dev_mouse]]>>=
(* a virtual "/dev/mouse" *)
val dev_mouse: Device.t
@

<<constant [[Virtual_mouse.dev_mouse]]>>=
let dev_mouse = { (*Device.default with*)
  name = "mouse";
  perm = Plan9.rw;

  <<method [[Virtual_mouse.dev_mouse.open_]]>>
  <<method [[Virtual_mouse.dev_mouse.close]]>>
  <<method [[Virtual_mouse.dev_mouse.read_threaded]]>>
  <<method [[Virtual_mouse.dev_mouse.write_threaded]]>>
}
@

% classic open/close with important mouse_opened field which tells
% the window manager that this is a graphical app
<<method [[Virtual_mouse.dev_mouse.open_]]>>=
open_ = (fun (w : Window.t) ->
  if w.mouse_opened
  then raise (Error "file in use");

  w.mouse_opened <- true;

  (* less: resized <- false? and race comment? *)
);
@

<<method [[Virtual_mouse.dev_mouse.close]]>>=
close = (fun (w : Window.t) ->
  (* stricter? check that was opened indeed? *)

  w.mouse_opened <- false;

  (* todo: resized? Refresh message?*)
);
@

\subsection{Reading part1}

%claude:
Reading [[/dev/mouse]] is where the channel-of-channels pattern
appears. The filesystem worker thread cannot simply read from a
queue---it needs to synchronize with the window thread, which is
the only thread allowed to access the window's mouse state.
So the worker first receives a channel from [[chan_devmouse_read]]
(this channel was sent by the window thread's [[Event.select]] when
it had mouse data ready), then receives the actual mouse state
on that channel.

<<method [[Virtual_mouse.dev_mouse.read_threaded]]>>=
(* a process is reading on its /dev/mouse; we must read from mouse
 * events coming to the window, events sent from the mouse thread.
 *)
read_threaded = (fun _offset count (w : Window.t) ->
  (* less: flushtag *)
  (* less: qlock active *)
  (* less: qlock unactive after answer? so need reorg this func? *)

  let chan = Event.receive w.chan_devmouse_read |> Event.sync in
  let m : Mouse.state    = Event.receive chan |> Event.sync in

  (* less: resize message *)

  let str = 
    spf "%c%11d %11d %11d %11d " 
      'm' m.pos.x m.pos.y (Mouse.int_of_buttons m.buttons) m.msec
  in
  (* bugfix: note that we do not honor_offset. /dev/mouse is a dynamic file *)
  Device.honor_count count str
);
@


<<[[Window.t]] mouse fields>>=
(* Threads_window.thread --> Thread_fileserver.dispatch(Read).
 * The channel inside the channel will be used to write a mouse state
 * to thread_fileserver.
*)
chan_devmouse_read: Mouse.state Event.channel Event.channel;
@


%claude:
This is the producer side of the channel-of-channels protocol for
[[/dev/mouse]]. The window thread includes an [[Event.send]] in
its [[select]] list {\em only} when there is a new mouse event
(detected by comparing [[mouse_counter]] with [[last_count_sent]]).
The send offers a fresh channel ([[chan_devmouse]]) to whoever is
waiting on [[chan_devmouse_read]]---which is the filesystem worker
thread handling a [[Tread]] for [[/dev/mouse]].

<<[[Threads_window.thread()]] other [[select]] elements>>=
(* sending *)
(if w.mouse_counter <> w.last_count_sent
 then [Event.send w.chan_devmouse_read chan_devmouse
        |> wrap (fun () -> SentChannelForMouseRead)]
 else []
) @
@
% Event.send! not Event.receive here, select can dispatch on
% receiving and sending if someone is ready on the other side to receive

<<[[Window.t]] mouse fields>>=
mutable last_count_sent: mouse_counter;
@


<<[[Threads_window.thread()]] channels creation>>=
let chan_devmouse = Event.new_channel () in
@

<<[[Threads_window.event]] other cases>>=
(* producing for thread_fileserver(Read Qmouse) *)
| SentChannelForMouseRead
@

<<[[Threads_window.thread()]] match [[ev]] other cases>>=
| SentChannelForMouseRead -> 
  mouse_out w chan_devmouse
@


%claude:
[<mouse_out>] is step~2 of the protocol: now that the filesystem
worker has the channel, send the actual mouse data on it.
If there are queued clicks, the oldest click is dequeued; otherwise
the current mouse position is sent. This means the application
always sees every click (in order), but may miss intermediate
mouse-move positions during high latency.

<<function [[Threads_window.mouse_out]]>>=
let mouse_out (w : Window.t) (chan : Mouse.state Event.channel) =
  (*/* send a queued event or, if the queue is empty, the current state */
    /* if the queue has filled, we discard all the events it contained. */
    /* the intent is to discard frantic clicking by the user during long latencies. */
  *)
  let m, counter =
    if Queue.length w.mouseclicks_queue > 0
    then Queue.take w.mouseclicks_queue 
    else w.last_mouse, w.mouse_counter
  in
  (* we use last_count_sent later to know if we are ready to send mouse
   * states to someone
   *)
  w.last_count_sent <- counter;
  Event.send chan m |> Event.sync
@
% and this send will go to the read_threaded 2nd receive above
% why this 2 steps procedure?

% after that the graphical app will have read the mouse state
% from the queue or current state



<<function [[Device.honor_count]]>>=
let honor_count count data =
  let len = String.length data in
  if len <= count
  then data
  else String.sub data 0 count
@

