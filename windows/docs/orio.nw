%******************************************************************************
\chapter{Filesystem Server}
%******************************************************************************
\label{chap:filesystem-server}

%claude:
This chapter covers the 9P protocol handling: how [[rio]]
responds to file operations (attach, walk, open, read, write,
close, stat) from its client processes. Each 9P operation is
handled by a case in [<dispatch>], which pattern-matches on the
request type---the OCaml equivalent of the C version's function
pointer table.

%%\section{Additional data structures}
% seen before File.devid, Device.t

%%\subsection{[[Qxxx]]}
%ocaml: use ADT
%%\subsection{[[dirtab]]}
%ocaml: toplevel_entries instead

%%\section{[[filsysrespond()]]}

\section{Attach}

%claude:
Attach is the first 9P operation after the version handshake.
It happens when a child process calls [[Plan9.mount]]: the kernel
sends a [[Tattach]] message with the user name and the ``aname''
string---which, for [[rio]], contains the window ID. This is how
the filesystem server associates each client connection with the
right [[Window.t]]: it parses the aname as an integer, looks up
the window in [[Globals.windows]], and stores it in the root fid's
[[win]] field.

% when is this called? just after Plan9.mount of winshell?
% probably, and get passed the w.id!

<<[[Threads_fileserver.dispatch()]] match [[request_typ]] cases>>=
(* Attach *)
| T.Attach (rootfid, _auth_fid_opt, uname, aname) ->
  (* stricter: *)
  if Hashtbl.mem fs.fids rootfid
  then failwith (spf "Attach: fid already used: %d" rootfid);

  (match () with
  | _ when uname <> fs.user ->
    error fs req (spf "permission denied, %s <> %s" uname fs.user)
  | _ ->
  (* less: could do that in a worker thread (if use qlock) *)
  (* less: newlymade, qlock all *)
  (try
     let wid = int_of_string aname in
     let w = Hashtbl.find Globals.windows wid in

     let entry = File.root_entry in
     let file_id = entry.code, wid in
     let qid = File.qid_of_fileid file_id entry.type_ in

     let file = File.{
       fid = rootfid; 
       qid = qid; 
       entry = entry;
       opened = None;
       win = w;
     } in
     Hashtbl.add fs.fids rootfid file;
     answer fs {req with P9.typ = P9.R (R.Attach qid) }
   with _exn ->
      error fs req (spf "unknown id in attach: %s" aname)
  (* less: incref, qunlock *)
  ))
@

% win = w!!

% return qid that encode the file_id which itself encodes the wid

<<[[File.t]] other fields>>=
(* The qid is what is returned by the "server" to identify a file (or dir).
 * It is mutable because a fid can be 'walked' to point to another file
 * on the server.
 *)
mutable qid: Plan9.qid;
@

%claude:
A [[fileid]] pairs the device code (which file: mouse, cons, etc.)
with the window ID, so each window has its own set of qids.
The encoding packs both into a single integer: the window ID is
shifted left by 8 bits, and the device code occupies the low 8 bits.
This is what the 9P protocol returns to the client as the file's
unique identifier.

<<type [[File.fileid]]>>=
(* will generate a Qid.path *)
type fileid = filecode * Window.wid
@

<<function [[File.qid_of_fileid]]>>=
let qid_of_fileid file_id typ =
  { path = int_of_fileid file_id;
    typ = typ;
    vers = 0;
  }
@

<<function [[File.int_of_fileid]]>>=
let int_of_fileid (qxxx, wid) = 
  (wid lsl 8) lor
  int_of_filecode qxxx
@
% the window and then deviceid

<<function [[File.int_of_filecode]]>>=
let int_of_filecode = function
  | Dir Root -> 0
  | File WinName -> 1
  | File Mouse -> 2
  | File Cons -> 3
  | File ConsCtl -> 4
  | File WinId -> 5
  | File Text -> 6
@


