let rec tree_make v l =
  <<[[Unzip.tree_make()]] sanity check [[l]]>>
  try
    Found (Hashtbl.find bits (v,l))
  with
    Not_found ->
      NeedBit (tree_make (v lsl 1) (l + 1) , tree_make (v lsl 1 lor 1) (l + 1))
in
