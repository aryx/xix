<<function [[Repository.commit_index]]>>=
let commit_index r author committer message =
  let aref = Refs.Head in
  let root_tree = Index.trees_of_index r.index 
    (fun t -> add_obj r (Objects.Tree t)) 
  in
  (* todo: execute pre-commit hook *)
