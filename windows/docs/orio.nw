\subsection{[[windows]]}

%claude:
The [[windows]] hash table holds all managed windows, keyed by
their integer ID. The [[topped]] counter is a logical timestamp:
each time a window is brought to the front, it gets the current
counter value, so comparing [[topped]] values determines z-order.

<<global [[Globals.windows]]>>=
let windows: (Window.wid, Window.t) Hashtbl.t = Hashtbl_.create ()
@

% move later? quite important to understand so better here probably
<<type [[Window.topped_counter]]>>=
type topped_counter = int
@

<<global [[Window.topped_counter]]>>=
let topped_counter =
  ref 0
@

<<[[Window.t]] wm fields>>=
mutable topped: topped_counter;
@

\subsection{[[current]]}
\label{sec:current}

%claude:
The [[current]] global tracks which window has the keyboard focus.
It plays a role similar to [[up]] (the current process) in the
\book{Kernel}: it is a global pointer that many parts of the code
consult to know where to route input events.

<<global [[Globals.current]]>>=
(* the man page of rio (rio(1)) uses the term 'current' 
 * old: was called 'input' in rio
 *)
let current: Window.t option ref  = ref None
@

<<function [[Globals.win]]>>=
(* a bit like cpu(), up() in the kernel, a convenient global *)
let win () =
  !current
@

\subsection{Graphical windows}

%claude:
[[rio]] distinguishes graphical from textual windows at runtime.
If a client opens [[/mnt/wsys/mouse]], the [[mouse_opened]] flag
is set to [[true]] and [[rio]] treats the window as graphical:
raw mouse events are forwarded to the application.
If [[mouse_opened]] is [[false]] (the default), the window is
treated as a terminal, and [[rio]] interprets mouse events itself
(for text selection, scrolling, etc.).
The [[raw_mode]] flag plays a similar role for the keyboard.

<<[[Window.t]] graphical window fields>>=
mutable mouse_opened: bool;
@

% can also have raw_mode in textual window but the real use is
% for graphical apps
<<[[Window.t]] graphical window fields>>=
mutable raw_mode: bool;
@

<<[[Window.t]] keyboard fields>>=
(* see also Window.terminal below for keys when in non-raw (buffered) mode *)
raw_keys: Keyboard.key Queue.t;
@

%meta:
% note that rio itself in main call Keyboard.init which turns
% on raw mode and access /dev/consctl, but the real one! (unless
% when rio is run under rio)



\subsection{Textual windows}

%claude:
A textual window (the default, used as a terminal) embeds a
[[Terminal.t]] record that holds the text buffer, cursor positions,
and rendering state. This is a separate type rather than inlining
all fields into [[Window.t]], which makes the separation between
windowing-system concerns and terminal-emulation concerns clearer.

<<[[Window.t]] textual window fields>>=
terminal: Terminal.t;
@
%ocaml: new intermediate type instead of putting all fields in Window.t

%claude:
The [[Terminal.t]] record has two layers: the {\em model} (text data
and cursor positions) and the {\em view} (the image surface and
layout rectangles for rendering). The key field is [[output_point]]:
it divides the text buffer into two halves---everything before it
is output from the application (already processed), and everything
after it is input typed by the user (not yet sent to the application).

<<type [[Terminal.t]]>>=
type t = {
  (* the model *)

  <<[[Terminal.t]] text data fields>>
  <<[[Terminal.t]] text cursor fields>>

  (* the view *)

  <<[[Terminal.t]] graphics fields>>

  (* misc *)

  <<[[Terminal.t]] other fields>>
}
@


<<[[Terminal.t]] text data fields>>=
(* growing array (simpler than a gap buffer).
 * alt: a growing string, like in Efuns.
 *)
mutable text: Rune.t array;
(* number of runes used in text (<= Array.length term.text) *)
mutable nrunes: int;

(* less: lines? like in Efuns? with EOF sentinel to simplify code? *)
@

<<[[Terminal.t]] text cursor fields>>=
(* where entered text go (and selection start) (old: q0 in rio) *)
mutable cursor: position;
mutable end_selection: position option;      (* old: q1 in rio) *)
@

<<type [[Terminal.position]]>>=
type position = {
  i: int;
}
@
<<constant [[Terminal.zero]]>>=
let zero = 
  { i = 0 }
@

<<[[Terminal.t]] text cursor fields>>=
(* Division between characters the host has seen and characters not 
 * yet transmitted. The position in the text that separates output from input.
 * old: qh in rio
 *)
mutable output_point: position;
@



<<[[Terminal.t]] graphics fields>>=
img: Image.t;

(* img.r without border and some extra space *)
r: Rectangle.t;
(* right side of r, and no bottom rectangle covering a line of
 * text with font below 
 *)
textr: Rectangle.t;
(* left side of r *)
scrollr: Rectangle.t;
@


%XXX
<<[[Terminal.t]] other fields>>=
(* first character visible in window from 'text' *)
mutable origin_visible: position;
mutable runes_visible: int;
@
<<[[Terminal.t]] other fields>>=
font: Font.t;
@
<<[[Terminal.t]] other fields>>=
(* this will alter which color to use to render the text *)
mutable is_selected: bool;
@
<<[[Terminal.t]] other fields>>=
(* alt: mutable colors: colors; *)
@


\section{Filesystem server}

%claude:
[[rio]] is not just a graphical application---it is also a
{filesystem server}. In \plan, any process can serve virtual
files by listening on a pipe and speaking the 9P protocol.
When a client process reads [[/dev/cons]] or [[/dev/mouse]],
the kernel translates that into a 9P message on the pipe,
and [[rio]]'s filesystem server thread handles it.

\subsection{[[Fileserver.t]]}%% and [[filsys]]}
%ocaml: no filsys global

%claude:
The [[Fileserver.t]] record holds the two ends of the pipe
that connects [[rio]] to its client processes. The [[clients_fd]]
end is inherited by child processes (via [[fork]]) and passed
to [[Plan9.mount]] so the kernel routes their file operations
through the pipe. The [[server_fd]] end is read by [[rio]]'s
filesystem server thread.

<<type [[Fileserver.t]]>>=
type t = {
  (* the pipe *)

  (* clients_fd will be shared by all the winshell processes *)
  clients_fd: Unix.file_descr;
  server_fd: Unix.file_descr;

  (* for security *)
  user: string;

  (* the files managed by the server currently-in-use by the client *)
  fids: (File.fid, File.t) Hashtbl.t;

  <<[[Fileserver.t]] other fields>>
}
@


\subsection{File state and file ids}

%claude:
A {fid} is a 9P concept: a handle that the client uses to refer
to a file on the server, similar to a file descriptor but at the
protocol level. The server maintains a [[File.t]] record for each
active fid, tracking which file it points to, whether it has been
opened, and---crucially---which [[Window.t]] it belongs to.
The [[win]] field is the bridge between the filesystem abstraction
and the windowing system: it lets the server know which window
a read or write request is for.

<<type [[File.fid]]>>=
(* This is maintained by the "client" (the kernel on behalf of a winshell) *)
type fid = Protocol_9P.fid
@

<<type [[File.t]]>>=
(* fid server-side state (a file) *)
type t = {
  (* The fid is maintained by the "client" (the kernel on behalf of winshell).
   * It is the key used to access information about a file used by
   * the client (it's redundant in File.t because it is also the key in
   * Fileserver.t.fids)
   *)
  fid: fid;

  (* the state *)
  mutable opened: Plan9.open_flags option;

  <<[[File.t]] other fields>>
  (* less: nrpart for runes *)
}
@

<<[[File.t]] other fields>>=
(* for stat (mutable for the same reason than qid) *)
mutable entry: dir_entry_short;
@

<<type [[File.dir_entry_short]]>>=
(* simpler than Plan9.dir_entry *)
type dir_entry_short = { 
  name: string;
  code: filecode;

  type_: Plan9.qid_type;
  (* just for the user; group and other are 'noperm' *)
  perm: Plan9.perm_property;
}
@

<<type [[File.filecode]]>>=
(* This is returned by the server (rio) to identify a file of the server *)
type filecode = 
  | Dir of dir
  | File of devid
@
<<type [[File.dir]]>>=
  and dir = 
    (* '/' 
     * old: was called Qdir in rio *)
    | Root
@

<<constant [[File.root_entry]]>>=
let root_entry = 
  { name = "."; code = Dir Root; type_ = N.QTDir; perm =  N.rx }
@



<<[[File.t]] other fields>>=
(* less: we could also use a wid *)
win: Window.t;
@
% get back the window of the process doing the request! very important!
% how do we get the window? during Attach and in Plan9.mount call
% we pass the window id to mount, which is then seen in Attach for
% the rootfid



%%\subsection{Workers and jobs: [[Xfid]]}
%ocaml: create read/write threads on the fly instead of worker pool
%%\subsection{9P callbacks: [[fcall]]}
%ocaml: use ADT for 9P request type, no need literal array, use
% pattern matching cases instead on request type with appropriate
% data passed

\section{Devices}
%ocaml: new section, new type

%claude:
Each virtual device file ([[/mnt/wsys/mouse]], [[/mnt/wsys/cons]], etc.)
is identified by a [[devid]] variant and implemented by a [[Device.t]]
record containing open/close/read/write callbacks. This is essentially
a vtable pattern: the filesystem server dispatches 9P operations to
the right device by looking up the [[devid]] in the [[all_devices]]
table.

<<type [[File.devid]]>>=
  and devid = 
    | WinName
    | Mouse
    (* todo: Cursor ... *)
    | Cons
    | ConsCtl

    | WinId
    | Text
@

<<constant [[Threads_fileserver.all_devices]]>>=
let all_devices : (File.devid * Device.t) list = [
  File.WinName , Virtual_draw.dev_winname;
  File.Mouse   , Virtual_mouse.dev_mouse;
  File.Cons    , Virtual_cons.dev_cons;
  File.ConsCtl , Virtual_cons.dev_consctl;
  
  File.WinId   , Dev_wm.dev_winid;
  File.Text    , Dev_textual_window.dev_text;
]
@
<<constant [[Threads_fileserver.toplevel_entries]]>>=
let toplevel_entries : File.dir_entry_short list =
  all_devices |> List.map (fun (devid, dev) ->
    File.{
      name = dev.D.name;
      code = File.File devid;
      type_ = Plan9.QTFile;
      perm = dev.D.perm;
    }
  )
@
% used for Walk


<<function [[Threads_fileserver.device_of_devid]]>>=
let device_of_devid (devid : File.devid) : Device.t =
  try 
    List.assoc devid all_devices
  with Not_found ->
    raise (Impossible (spf "all_devices is not correctly set; missing code %d"
             (File.int_of_filecode (File.File devid))))
@


%claude:
The [[read_threaded]] and [[write_threaded]] callbacks are called
``threaded'' because they may block waiting on channels (e.g., waiting
for the next mouse event). The filesystem server spawns a new OCaml
thread for each read or write request so that blocking does not
stall other 9P operations.

<<type [[Device.t]]>>=
type t = {
  (* ex: "winname", "cons" *)
  name: string;
  perm: Plan9.perm_property;

  (* called when a process is opening/closing the device *)
  open_: Window.t -> unit;
  close: Window.t -> unit;
  
  (* called when a process is reading/writing on the device.
   *
   * we need to thread 'read' (and 'write') because this operation may spend
   * some time waiting while receiving and sending information on channels.
   * 
   * Note that 'read' takes an offset (and count) because each device 
   * can honor or not the offset requirements. For instance,
   * /dev/winname does honor offset but /dev/mouse does not.
   *)
  read_threaded: int64 -> int -> Window.t -> string (* bytes *);
  write_threaded: int64 -> string (* bytes *) -> Window.t -> unit;
}
@
% methods

<<constant [[Device.default]]>>=
let default = {
  name = "<default>";
  perm = Plan9.rw;
  open_ = (fun _ -> ());
  close = (fun _ -> ());
  read_threaded = (fun _ _ _ -> "");
  write_threaded = (fun _ _ _ -> ());
}
@


%ocaml: Windows.nw Core DS topics NOT needed in OCaml version:
% - Ref/Qlock concurrency fields: OCaml has no data races (single-domain), no need for reference counting or locks
% - screenr vs i->r coordinate conversion: not yet using originwindow, so always equal
% - Xfid worker pool type: OCaml creates threads on the fly for read/write, no pool needed
% - fcall dispatch table (C function pointer array): OCaml uses pattern matching on ADT
% - globals (display, view, screen, mousectl, keyboardctl): passed as function arguments

%******************************************************************************
\chapter{[[main()]]}
%******************************************************************************
\label{chap:main}

%claude:
[[rio]] has a triple nature that is visible right in [[thread_main]]:
it is a graphical application (it calls [[Draw.init]]),
a filesystem server (it calls [[Fileserver.init]]),
and a concurrent application (it creates multiple threads and
waits on an exit channel).

<<toplevel [[Main._1]]>>=
let _ = 
  Cap.main (fun (caps : Cap.all_caps) ->
     Exit.exit caps (Exit.catch (fun () -> CLI.main caps (CapSys.argv caps)))
  )
@


%claude:
The capability type lists everything [[rio]] needs from the
operating system. This is the complete set of resources: drawing,
input devices, process management ([[fork]]/[[exec]]/[[chdir]]),
and namespace manipulation ([[mount]]/[[bind]]) to set up
virtual devices for each window.

<<type [[CLI.caps]]>>=
(* Need:
 * - draw/mouse/keyboard because rio multiplexes access to those devices
 * - fork/exec/chdir when creating new windows which trigger new rc
 *   processes run possibly from different directories.
 * - open_in: for /dev/winname access
 * - mount/bind: for the window to mount the rio fileserver to /mnt/wsys
 *   and then bind it to /dev for virtual /dev/{cons,mouse,...}
 *)
type caps = < 
    Cap.draw; Cap.mouse; Cap.keyboard;
    Cap.fork; Cap.exec; Cap.chdir;
    Cap.open_in;
    Cap.mount; Cap.bind
  >
@

<<signature [[CLI.main]]>>=
(* entry point (can also raise Exit.ExitCode) *)
val main: <caps; Cap.stdout; Cap.stderr; ..> ->
  string array -> Exit.t
@

<<constant [[CLI.usage]]>>=
let usage = 
  "usage: rio [options]"
@


<<function [[CLI.main]]>>=
let main (caps : < caps; Cap.stdout; Cap.stderr; ..>) (argv : string array) :
    Exit.t =
  <<[[CLI.main()]] locals>>
  let options = [
    <<[[CLI.main()]] [[options]] elements>>
  ] |> Arg.align
  in
  (* This may raise ExitCode *)
  Arg_.parse_argv caps argv options (fun _f -> Arg.usage options usage) usage;
  <<[[CLI.main()]] logging setup>>
  try 
    (* the main call *)
    thread_main caps
  with exn ->
      <<[[CLI.main()]] handle [[exn]]>>
@


<<signature [[CLI.thread_main]]>>=
(* main thread which will itself create mouse/keyboard/fs/... threads *)
val thread_main: < caps; ..> -> Exit.t
@

%claude:
The structure of [[thread_main]] mirrors [[rio]]'s triple nature.
First, it initializes the display and allocates colors (graphical
application). Then it creates the filesystem server pipe
(filesystem server). Finally, it spawns the mouse, keyboard, and
fileserver threads, and blocks on [[exit_chan]] waiting for
someone to send an exit code---which happens when the user selects
``Exit'' from the right-click menu.

<<function [[CLI.thread_main]]>>=
let thread_main (caps: < caps; .. >) : Exit.t =

